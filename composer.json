{
  "name": "jdwx/cli",
  "description": "An extensible CLI framework.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JDWX\\CLI\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3.0",
    "ext-readline": "*",
    "jdwx/args": "^1.0",
    "jdwx/app": "^1.1.3",
    "jdwx/strict": "^1.0.22",
    "psr/log": "^3.0",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "jetbrains/phpstorm-attributes": "^1.0",
    "phan/phan": "^v6",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12"
  },
  "scripts": {
    "phan": "PHAN_ALLOW_XDEBUG=1 php -d xdebug.mode=off vendor/bin/phan --analyze-twice",
    "phpstan": "phpstan",
    "test": "vendor/bin/phpunit tests"
  }
}
